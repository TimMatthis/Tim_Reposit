              "html" : "<p><span style=\"font-size: 12px; line-height: 1em;\">Copyright&nbsp;© {{ year }} Reposit Power, All rights reserved.</span></p>\n<p style=\"line-height: 1em;\"><span style=\"font-size: 12px;\"><strong>Our mailing address is:</strong></span><br><span style=\"font-size: 12px;\">{{ site_settings.company_name }}</span><br><span style=\"font-size: 12px;\">{{ site_settings.company_street_address_1 }}</span><br><span style=\"font-size: 12px;\">{{ site_settings.company_street_address_2 }}</span><span style=\"font-size: 12px;\">{{ site_settings.company_city }},&nbsp;{{ site_settings.company_state }}&nbsp;{{ site_settings.company_zip }}</span><br><span style=\"font-size: 12px;\">{{ site_settings.company_country }}</span></p>\n<p><span style=\"font-size: 12px; line-height: 1em;\"></span><span style=\"font-size: 12px; line-height: 1em;\"><a target=\"_blank\" href=\"{{ unsubscribe_link }}\" style=\"text-decoration: underline; whitespace: nowrap; color: {{ secondary_font_color }};\" data-unsubscribe=\"true\" rel=\"noopener\">Want to change how you receive these emails?</a></span><br><span style=\"font-size: 12px; line-height: 1em;\">You can&nbsp;<a target=\"_blank\" href=\"{{ unsubscribe_link }}\" style=\"text-decoration: underline; whitespace: nowrap; color: {{ secondary_font_color }};\" data-unsubscribe=\"true\" rel=\"noopener\">update your preferences</a>&nbsp;or&nbsp;<a target=\"_blank\" href=\"{{ unsubscribe_link_all }}\" style=\"text-decoration: underline; whitespace: nowrap; color: {{ secondary_font_color }};\" data-unsubscribe=\"true\" rel=\"noopener\">unsubscribe</a>&nbsp;from this list.&nbsp;</span></p>",
