              }
            }, {
              "0" : {
                "x" : 0,
                "w" : 12,
                "name" : "module_1507178617246127",
                "label" : "Blog Content",
                "type" : "blog_content",
                "params" : {
                  "css_class" : "",
                  "css_id" : "",
                  "css_id_str" : "",
                  "css_style" : "",
                  "wrapping_html" : "",
                  "per_widget_wrapper_html" : "",
                  "overrideable" : false,
                  "blog_listing_source" : "<div class=\"blog-section\">\n    <div class=\"blog-listing-wrapper cell-wrapper\">\n{# simple_list_page indicates the \"blog/all\" page, which is a list of links to every blog post #}\n        <div class=\"post-listing{% if simple_list_page %}-simple{% endif %}\">\n            {% if blog_author %}\n                <div class=\"hs-author-profile\">\n                    <h2 class=\"hs-author-name\">{{ blog_author.display_name }}</h2>\n                    {% if blog_author.avatar %} <div class=\"hs-author-avatar\"> <img src=\"{{ blog_author.avatar }}\" alt=\"{{ blog_author.display_name }}\"> </div> {% endif %}\n                    <div class=\"hs-author-bio\">{{ blog_author.bio }}</div>\n                    {% if blog_author.has_social_profiles %}\n                        <div class=\"hs-author-social-section\">\n                            <span class=\"hs-author-social-label\">Find me on:</span>\n                            <div class=\"hs-author-social-links\">\n                                {% if blog_author.facebook %}\n                                    <a href=\"{{ blog_author.facebook }}\" target=\"_blank\" class=\"hs-author-social-link hs-social-facebook\">&nbsp;</a>\n                                {% endif %}\n                                {% if blog_author.linkedin %}\n                                    <a href=\"{{ blog_author.linkedin }}\" target=\"_blank\" class=\"hs-author-social-link hs-social-linkedin\">&nbsp;</a>\n                                {% endif %}\n                                {% if blog_author.twitter %}\n                                    <a href=\"{{ blog_author.twitter }}\" target=\"_blank\" class=\"hs-author-social-link hs-social-twitter\">&nbsp;</a>\n                                {% endif %}\n                                {% if blog_author.google_plus %}\n                                    <a href=\"{{ blog_author.google_plus }}?rel=author\" target=\"_blank\" class=\"hs-author-social-link hs-social-google-plus\">&nbsp;</a>\n                                {% endif %}\n                            </div>\n                        </div>\n                    {% endif %}\n                </div>\n                <h3 class=\"hs-author-listing-header\">Recent Posts</h3>\n            {% endif %}\n                {% for content in contents %}\n                    {% if loop.index  > 3 and current_page_num <= 1 %}\n                        <div class=\"post-item\">\n                            {% if not simple_list_page %}\n                                <a href=\"{{content.absolute_url}}\">\n                                    {% if content.post_list_summary_featured_image %}\n                                        <div class=\"hs-featured-image-wrapper\" style=\"background-image: url('{{ content.post_list_summary_featured_image }}')\">\n                                           \n                                        </div>\n                                    {% endif %}\n                                    <div class=\"post-content\">\n                                        <div class=\"post-header\">\n                                            <h2>{{ content.name }}</h2>\n                                        </div>\n                                        <div class=\"hs-post-date\">\n                                            {{ content.publish_date_local_time.strftime('%e') }} {{ content.publish_date_local_time.strftime('%B') }} {{ content.publish_date_local_time.strftime('%Y') }}\n                                        </div>\n                                    </div>\n                                </a>\n        \n                            {% endif %}\n                        </div>\n                    {% endif %}\n                    {% if current_page_num > 1 %}\n                        <div class=\"post-item\">\n                                {% if not simple_list_page %}\n                                    <a href=\"{{content.absolute_url}}\">\n                                        {% if content.post_list_summary_featured_image %}\n                                            <div class=\"hs-featured-image-wrapper\" style=\"background-image: url('{{ content.post_list_summary_featured_image }}')\">\n                                               \n                                            </div>\n                                        {% endif %}\n                                        <div class=\"post-content\">\n                                            <div class=\"post-header\">\n                                                <h2>{{ content.name }}</h2>\n                                            </div>\n                                            <div class=\"hs-post-date\">\n                                                {{ content.publish_date_local_time.strftime('%e') }} {{ content.publish_date_local_time.strftime('%B') }} {{ content.publish_date_local_time.strftime('%Y') }}\n                                            </div>\n                                        </div>\n                                    </a>\n            \n                                {% endif %}\n                        </div>\n                    {% endif %}\n                {% endfor %}\n\n        </div>\n        {% if not simple_list_page %}\n            <div class=\"blog-pagination\">\n                <!--{% if last_page_num %}\n                    <a class=\"previous-posts-link\" href=\"{{ blog_page_link(last_page_num) }}\">Previous</a>\n                {% endif %}\n                    <a class=\"all-posts-link\" href=\"{{ group.absolute_url }}/all\">All posts</a>-->\n                {% if next_page_num %}\n                    <a class=\"next-posts-link load-more\" href=\"{{ blog_page_link(next_page_num) }}\"> </a>\n                {% endif %}\n            </div>\n        {% endif %}\n    </div>\n</div>\n\n",
                  "blog_post_source" : "<!-- this blog uses separate master template for listing page  --> "
