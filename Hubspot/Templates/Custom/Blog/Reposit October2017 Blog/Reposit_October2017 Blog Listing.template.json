                  "wrapping_html" : "",
                  "per_widget_wrapper_html" : "",
                  "overrideable" : false,
                  "blog_listing_source" : "<div class=\"cm-top-3-post-wrapper\">\n    {% for content in contents %}\n        {% if loop.index < 4 and current_page_num <= 1 %}\n            <div class=\"custom-recent-post-item {% if not content.post_list_summary_featured_image %} no-image {% endif %}\">\n                    {% if content.post_list_summary_featured_image %}\n                \t\t<div class=\"hs-rec-featured-image-wrapper\">\n                \t\t\t<a href=\"{{ content.absolute_url}}\" title=\"\" class=\"hs-rec-featured-image-link\">\n                \t\t\t\t<img src=\"{{ content.post_list_summary_featured_image }}\" class=\"hs-rec-featured-image\">\n                \t\t\t</a>\n                \t\t</div>\n                \t{% endif %}\n                    <div class=\"rec-post-content\">\n            \t\t    <h2 class=\"post-title\"><a href=\"{{content.absolute_url}}\">{{ content.name }}</a></h2>\n                \t\t    <div class=\"rec-hs-author\">\n                \t\t        Written by\n                                    {%if content.blog_post_author %}\n                                        {{ content.blog_post_author.display_name }} on \n                                        {{ content.publish_date_local_time.strftime('%e') }} {{ content.publish_date_local_time.strftime('%B') }} {{ content.publish_date_local_time.strftime('%Y') }}\n                                    {% endif %}\n                                    {% if content.topic_list %}\n                    \t\t\t\t <span id=\"hubspot-topic_data\"> in\n                    \t\t\t\t\t{% for topic in content.topic_list %}\n                    \t\t\t\t\t\t{{ topic.name }}{% if not loop.last %},{% endif %}\n                    \t\t\t\t\t{% endfor %}\n                    \t\t\t\t </span>\n                \t\t\t        {% endif %}\n                \t\t    </div>\n                \t\t    <div class=\"post-body\">\n                \t\t\t\t<!--post summary-->\n                \t\t\t\t{{ content.post_list_content|striptags|truncatehtml(150, '...' , false)}}\n                \t\t\t\t<a class=\"read-more-link\" href=\"{{ content.absolute_url }}\">Read More</a>\n                            </div>\n            \t\t</div>\n            </div>\n        {% endif %}\n    {% endfor %}\n</div>",
                  "blog_post_source" : "<!-- this blog uses separate master template for listing page  --> "
                },
                "rows" : [ ],
                "rowMetaData" : [ ],
                "cells" : [ ],
                "cssId" : "",
                "cssClass" : "",
