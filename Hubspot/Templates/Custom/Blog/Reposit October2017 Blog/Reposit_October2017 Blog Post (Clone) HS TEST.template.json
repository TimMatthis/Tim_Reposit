      "0" : {
        "x" : 0,
        "w" : 12,
        "name" : "module_150719482420758",
        "label" : "Related Post Slider",
        "type" : "raw_jinja",
        "params" : {
          "css_class" : "",
          "css_id" : "",
          "css_id_str" : "",
          "css_style" : "",
          "wrapping_html" : "",
          "per_widget_wrapper_html" : "",
          "overrideable" : false,
          "value" : "<div class=\"recent-post-wrapper\">\r\n<div class=\"page-center\">\r\n    {% if content.topic_list %}\r\n      <h3>Related posts</h3>\r\n      <div class=\"owl-carousel\">\r\n      {% set max_posts = 10 %}{# Set the max number of related posts to be output to the page here #}\r\n      {% set post_list = [] %}\r\n      {% for topic in content.topic_list %}\r\n        {% set post_list = post_list + blog_recent_topic_posts('default', topic.slug, max_posts + 1 ) %}\r\n        {% if loop.last %}\r\n          {% set post_list = post_list|sort(true, false, 'publish_date')|unique('name') %}\r\n          {% set i = 0 %}\r\n          {% for post in post_list %}\r\n            {% if content.absolute_url != post.absolute_url and i < max_posts %}\r\n            <div class=\"item\">\r\n              <div class=\"related-post-item {% if not post.featured_image %} no-image {% endif %}\">\r\n                  <a href=\"{{post.absolute_url}}\">\r\n                    <div class=\"related-image {% if not post.featured_image %} no-image {% endif %}\" style=\"background-image: url({{ post.featured_image }})\"></div>\r\n                    <div class=\"post-content\">\r\n                        <h2 class=\"related-title\">{{ post.name}}</h2>\r\n                        <div class=\"hs-post-date\">\r\n                            {{ post.publish_date_local_time.strftime('%e') }} {{ post.publish_date_local_time.strftime('%B') }} {{ post.publish_date_local_time.strftime('%Y') }}\r\n                        </div>\r\n                    </div>\r\n                </a>\r\n              </div>\r\n            </div>\r\n              {% set i = i + 1 %}\r\n            {% endif %}\r\n          {% endfor %}\r\n        {% endif %}\r\n      {% endfor %}\r\n      </div>\r\n    {% endif %}\r\n</div>\r\n</div>\r\n\r\n\r\n{{ require_css(\"//cdn2.hubspot.net/hubfs/3445699/Reposit%20October2017%20Theme/Css/owl.carousel.min.css\") }}\r\n{{ require_css(\"//cdn2.hubspot.net/hubfs/3445699/Reposit%20October2017%20Theme/Css/owl.theme.default.min1.css\") }}\r\n\r\n<!-- javascript -->\r\n{{ require_js(\"//cdn2.hubspot.net/hubfs/3445699/Reposit%20October2017%20Theme/JS/owl.carousel.js\") }}\r\n{% require_js %}\r\n<script type=\"text/javascript\">\r\n$( document ).ready(function() {\r\n    $('.owl-carousel').owlCarousel({\r\n        loop:true,\r\n        margin:10,\r\n        nav:true,\r\n        autoplay:true,\r\n        dots:false,\r\n\t\tresponsive:{\r\n\t\t\t0:{\r\n\t\t\t\titems:1\r\n\t\t\t},\r\n\t\t\t768:{\r\n\t\t\t\titems:3\r\n\t\t\t},\r\n\t\t\t1023:{\r\n\t\t\t\titems:4\r\n\t\t\t}\r\n\t\t}\r\n\t});\r\n});\r\n</script>\r\n{% end_require_js %} \r\n"
